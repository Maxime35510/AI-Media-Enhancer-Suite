# Local tools and binaries
Tools/**
!Tools/.gitkeep

# Input media stays local
To enhance/**
!To enhance/.gitkeep

# Final outputs stay local
Enhanced/**
!Enhanced/.gitkeep

# Work files, logs, split segments, temp files
Segments/**
!Segments/.gitkeep

# Media files should never be committed
*.mp4
*.mkv
*.mov
*.avi
*.m4v
*.webm
*.png
*.jpg
*.jpeg
*.bmp
*.webp
*.tif
*.tiff

# Logs and temp files
*.log
*.tmp
*.part

# Windows clutter
Thumbs.db
desktop.ini
